# =============================================================================
# Heimdal Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required keys are marked with (REQUIRED). The platform will not start
# without them. Optional keys have defaults shown in comments.
# =============================================================================

# -- AIS Data Source ----------------------------------------------------------

# API key for the AIS WebSocket data feed (REQUIRED)
AIS_API_KEY=

# Comma-separated bounding boxes for AIS position filtering.
# Format: lat_min,lon_min,lat_max,lon_max per box.
# Default: worldwide (no filtering)
AIS_BOUNDING_BOXES=worldwide

# Comma-separated ship type codes to ingest.
# Leave empty to ingest all ship types.
AIS_SHIP_TYPES=

# -- Database -----------------------------------------------------------------

# PostgreSQL password for the heimdal user.
# Default: heimdal_dev (local development only — change in production)
DB_PASSWORD=heimdal_dev

# PostgreSQL port on the host machine.
# Default: 5432
DB_PORT=5432

# -- API Server ---------------------------------------------------------------

# Port to expose the API server on the host machine.
# Default: 8000
API_PORT=8000

# -- Frontend -----------------------------------------------------------------

# Port to expose the frontend on the host machine.
# Default: 3000
FRONTEND_PORT=3000

# Cesium Ion access token for 3D globe rendering.
# Get one at https://ion.cesium.com/tokens
CESIUM_ION_TOKEN=

# -- Enrichment ---------------------------------------------------------------

# Global Fishing Watch API token (REQUIRED for enrichment service)
# Register at https://globalfishingwatch.org/our-apis/
GFW_API_TOKEN=

# Interval in hours between enrichment polling cycles.
# Default: 6
ENRICHMENT_INTERVAL=6

# Number of days to look back for GFW fishing events.
# Default: 30
GFW_EVENTS_LOOKBACK_DAYS=30

# -- Logging ------------------------------------------------------------------

# Log output format: "json" (default) for structured JSON, "text" for
# human-readable output during local development.
LOG_FORMAT=json

# Minimum log level: DEBUG, INFO (default), WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO
